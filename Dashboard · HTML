<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Job Dashboard | Howard Construction Inc.</title>
<meta name="description" content="Internal job management dashboard for Howard Construction Inc. Track active projects, crew scheduling, hours, and client updates across Northern California job sites.">
<meta name="robots" content="noindex, nofollow">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0A1628; --navy2:#0D2B4E; --blue:#1565C0; --blue-dk:#0D47A1;
  --accent:#F9A825; --bg:#F0F4F8; --card:#FFFFFF; --ink:#0A1628;
  --muted:#5A6B7D; --line:#E1E8F0; --green:#2E7D32; --amber:#F9A825; --red:#D32F2F;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Outfit',system-ui,sans-serif;background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased;}

/* TOP BAR */
.topbar{background:var(--card);border-bottom:2px solid var(--blue);position:sticky;top:0;z-index:100;}
.topbar-inner{max-width:1280px;margin:0 auto;padding:12px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;}
.topbar img{height:46px;width:auto;display:block;}
.topbar-right{display:flex;align-items:center;gap:14px;}
.back-link{font-size:13px;color:var(--blue);text-decoration:none;font-weight:600;display:flex;align-items:center;gap:5px;}
.back-link:hover{text-decoration:underline;}
.crew-badge{font-size:12px;background:rgba(21,101,192,0.1);color:var(--blue);padding:6px 12px;border-radius:100px;font-weight:600;}

/* HEADER */
.dash-head{max-width:1280px;margin:0 auto;padding:28px 20px 8px;}
.dash-head h1{font-family:'Playfair Display',serif;font-size:28px;font-weight:900;color:var(--navy);}
.dash-head p{font-size:14px;color:var(--muted);margin-top:4px;}

/* STAT STRIP */
.stats{max-width:1280px;margin:0 auto;padding:18px 20px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.stat{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:16px 18px;}
.stat-num{font-family:'Playfair Display',serif;font-size:30px;font-weight:900;color:var(--blue);line-height:1;}
.stat-lbl{font-size:12px;color:var(--muted);margin-top:6px;font-weight:500;}
.stat.accent .stat-num{color:var(--accent);}
.stat.green .stat-num{color:var(--green);}

/* TABS */
.tabs{max-width:1280px;margin:0 auto;padding:8px 20px 0;display:flex;gap:6px;border-bottom:1px solid var(--line);}
.tab{background:none;border:none;font-family:inherit;font-size:14px;font-weight:600;color:var(--muted);padding:12px 18px;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-1px;transition:all .2s;}
.tab.active{color:var(--blue);border-bottom-color:var(--blue);}
.tab:hover{color:var(--navy);}

/* CONTENT */
.content{max-width:1280px;margin:0 auto;padding:22px 20px 60px;}
.panel{display:none;}
.panel.active{display:block;animation:fade .3s;}
@keyframes fade{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

.panel-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:12px;}
.panel-head h2{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--navy);}
.btn{background:var(--blue);color:#fff;border:none;border-radius:9px;padding:10px 18px;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:background .2s;}
.btn:hover{background:var(--blue-dk);}
.btn svg{width:16px;height:16px;}
.btn-ghost{background:rgba(21,101,192,0.08);color:var(--blue);}
.btn-ghost:hover{background:rgba(21,101,192,0.16);}

/* JOB CARDS */
.jobs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:16px;}
.job{background:var(--card);border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:box-shadow .2s,transform .2s;}
.job:hover{box-shadow:0 8px 28px rgba(13,43,78,0.1);transform:translateY(-2px);}
.job-top{padding:16px 18px 12px;border-bottom:1px solid var(--line);}
.job-name-row{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;}
.job-name{font-size:16px;font-weight:700;color:var(--navy);}
.job-client{font-size:13px;color:var(--muted);margin-top:2px;}
.job-status{font-size:11px;font-weight:700;padding:4px 10px;border-radius:100px;white-space:nowrap;text-transform:uppercase;letter-spacing:.5px;}
.s-planning{background:rgba(90,107,125,0.14);color:#5A6B7D;}
.s-foundation{background:rgba(123,79,40,0.14);color:#7B4F28;}
.s-framing{background:rgba(249,168,37,0.18);color:#B45309;}
.s-rough{background:rgba(21,101,192,0.14);color:#1565C0;}
.s-finishing{background:rgba(106,76,156,0.14);color:#6A4C9C;}
.s-inspection{background:rgba(211,47,47,0.12);color:#D32F2F;}
.s-complete{background:rgba(46,125,50,0.14);color:#2E7D32;}
.job-body{padding:14px 18px;}
.job-progress-lbl{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:6px;font-weight:500;}
.job-progress-lbl b{color:var(--navy);}
.progress-track{height:8px;background:var(--line);border-radius:100px;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--accent));border-radius:100px;transition:width .4s;}
.job-meta{display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;font-size:12.5px;color:var(--muted);}
.job-meta div{display:flex;align-items:center;gap:5px;}
.job-meta svg{width:14px;height:14px;color:var(--blue);}
.job-foot{padding:12px 18px;background:#F7FAFD;border-top:1px solid var(--line);display:flex;gap:8px;}
.job-foot button{flex:1;font-size:12.5px;padding:8px;border-radius:7px;border:1px solid var(--line);background:#fff;color:var(--navy);font-family:inherit;font-weight:600;cursor:pointer;transition:all .15s;}
.job-foot button:hover{border-color:var(--blue);color:var(--blue);}

/* CREW / SCHEDULE */
.crew-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;}
.crew-card{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:16px;}
.crew-top{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.crew-av{width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--blue-dk));color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;}
.crew-name{font-weight:700;font-size:15px;color:var(--navy);}
.crew-role{font-size:12px;color:var(--muted);}
.crew-assign{font-size:13px;padding:8px 12px;background:#F7FAFD;border-radius:8px;color:var(--navy);margin-top:8px;}
.crew-assign span{color:var(--muted);font-size:12px;}
.crew-status{font-size:11px;font-weight:700;padding:3px 9px;border-radius:100px;margin-left:auto;}
.on-site{background:rgba(46,125,50,0.14);color:var(--green);}
.off{background:rgba(90,107,125,0.14);color:var(--muted);}

/* HOURS TABLE */
.hours-table{background:var(--card);border:1px solid var(--line);border-radius:12px;overflow:hidden;}
.hours-row{display:grid;grid-template-columns:1.4fr 1.6fr 1fr 0.8fr;gap:10px;padding:13px 18px;border-bottom:1px solid var(--line);font-size:13.5px;align-items:center;}
.hours-row:last-child{border-bottom:none;}
.hours-row.head{background:#F7FAFD;font-weight:600;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}
.hours-row .h-name{font-weight:600;color:var(--navy);}
.hours-total{font-weight:700;color:var(--blue);}

/* MODAL */
.modal-bg{position:fixed;inset:0;background:rgba(10,22,40,0.6);z-index:1000;display:none;align-items:flex-start;justify-content:center;padding:40px 16px;overflow-y:auto;}
.modal-bg.show{display:flex;}
.modal{background:#fff;border-radius:16px;width:100%;max-width:480px;padding:26px;}
.modal h3{font-family:'Playfair Display',serif;font-size:20px;color:var(--navy);margin-bottom:18px;}
.field{margin-bottom:14px;}
.field label{display:block;font-size:13px;font-weight:600;color:var(--navy);margin-bottom:6px;}
.field input,.field select,.field textarea{width:100%;border:1.5px solid var(--line);border-radius:9px;padding:10px 13px;font-family:inherit;font-size:14px;color:var(--ink);outline:none;background:#fff;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--blue);}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.modal-foot{display:flex;gap:10px;margin-top:8px;}
.modal-foot .btn{flex:1;justify-content:center;}

.empty{text-align:center;padding:50px 20px;color:var(--muted);}
.empty svg{width:54px;height:54px;color:var(--line);margin-bottom:14px;}
.empty p{font-size:15px;margin-bottom:6px;}
.empty span{font-size:13px;}

@media(max-width:760px){
  .stats{grid-template-columns:1fr 1fr;}
  .dash-head h1{font-size:23px;}
  .topbar img{height:38px;}
  .hours-row{grid-template-columns:1.3fr 1fr 0.8fr;font-size:12.5px;padding:11px 14px;}
  .hours-row .h-site{display:none;}
  .tab{padding:11px 13px;font-size:13px;}
  .content{padding:18px 14px 50px;}
  .stats{padding:16px 14px;}
}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <a href="index.html"><img src="data:image/svg+xml;base64," alt="Howard Construction Inc."></a>
    <div class="topbar-right">
      <span class="crew-badge">Crew Portal</span>
      <a href="index.html" class="back-link">&larr; Main Site</a>
    </div>
  </div>
</div>

<div class="dash-head">
  <h1>Job Dashboard</h1>
  <p id="dashDate">Loading...</p>
</div>

<div class="stats">
  <div class="stat"><div class="stat-num" id="statActive">0</div><div class="stat-lbl">Active Jobs</div></div>
  <div class="stat accent"><div class="stat-num" id="statWeek">0</div><div class="stat-lbl">Due This Month</div></div>
  <div class="stat green"><div class="stat-num" id="statCrew">0</div><div class="stat-lbl">Crew On Site</div></div>
  <div class="stat"><div class="stat-num" id="statHours">0</div><div class="stat-lbl">Hours This Week</div></div>
</div>

<div class="tabs">
  <button class="tab active" data-tab="jobs">Jobs</button>
  <button class="tab" data-tab="crew">Crew &amp; Schedule</button>
  <button class="tab" data-tab="hours">Hours Log</button>
</div>

<div class="content">

  <!-- JOBS PANEL -->
  <div class="panel active" id="panel-jobs">
    <div class="panel-head">
      <h2>Active Projects</h2>
      <button class="btn" onclick="openJobModal()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>New Job</button>
    </div>
    <div class="jobs-grid" id="jobsGrid"></div>
  </div>

  <!-- CREW PANEL -->
  <div class="panel" id="panel-crew">
    <div class="panel-head">
      <h2>Crew &amp; Today's Assignments</h2>
      <button class="btn" onclick="openCrewModal()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Add Crew</button>
    </div>
    <div class="crew-grid" id="crewGrid"></div>
  </div>

  <!-- HOURS PANEL -->
  <div class="panel" id="panel-hours">
    <div class="panel-head">
      <h2>This Week's Hours</h2>
      <button class="btn" onclick="openHoursModal()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Log Hours</button>
    </div>
    <div class="hours-table" id="hoursTable"></div>
  </div>

</div>

<!-- JOB MODAL -->
<div class="modal-bg" id="jobModal">
  <div class="modal">
    <h3 id="jobModalTitle">New Job</h3>
    <input type="hidden" id="jobId">
    <div class="field"><label>Project Name</label><input type="text" id="jobName" placeholder="e.g. Sonoma Vista Residence"></div>
    <div class="field"><label>Client Name</label><input type="text" id="jobClient" placeholder="e.g. The Andersons"></div>
    <div class="field"><label>Location</label><input type="text" id="jobLocation" placeholder="e.g. Santa Rosa, CA"></div>
    <div class="field-row">
      <div class="field"><label>Phase</label><select id="jobStatus">
        <option value="planning">Planning</option>
        <option value="foundation">Foundation</option>
        <option value="framing">Framing</option>
        <option value="rough">Rough-In</option>
        <option value="finishing">Finishing</option>
        <option value="inspection">Inspection</option>
        <option value="complete">Complete</option>
      </select></div>
      <div class="field"><label>Progress %</label><input type="number" id="jobProgress" min="0" max="100" value="0"></div>
    </div>
    <div class="field-row">
      <div class="field"><label>Crew Assigned</label><input type="number" id="jobCrew" min="0" value="0"></div>
      <div class="field"><label>Target Date</label><input type="date" id="jobDate"></div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" onclick="closeModal('jobModal')">Cancel</button>
      <button class="btn" onclick="saveJob()">Save Job</button>
    </div>
  </div>
</div>

<!-- CREW MODAL -->
<div class="modal-bg" id="crewModal">
  <div class="modal">
    <h3 id="crewModalTitle">Add Crew Member</h3>
    <input type="hidden" id="crewId">
    <div class="field"><label>Name</label><input type="text" id="crewName" placeholder="e.g. Mike Torres"></div>
    <div class="field"><label>Role</label><input type="text" id="crewRole" placeholder="e.g. Lead Framer"></div>
    <div class="field"><label>Assigned To</label><input type="text" id="crewAssign" placeholder="e.g. Sonoma Vista Residence"></div>
    <div class="field"><label>Status Today</label><select id="crewStatus">
      <option value="on-site">On Site</option>
      <option value="off">Off / Unassigned</option>
    </select></div>
    <div class="modal-foot">
      <button class="btn btn-ghost" onclick="closeModal('crewModal')">Cancel</button>
      <button class="btn" onclick="saveCrew()">Save</button>
    </div>
  </div>
</div>

<!-- HOURS MODAL -->
<div class="modal-bg" id="hoursModal">
  <div class="modal">
    <h3>Log Hours</h3>
    <div class="field"><label>Crew Member</label><input type="text" id="hoursName" placeholder="e.g. Mike Torres"></div>
    <div class="field"><label>Job Site</label><input type="text" id="hoursSite" placeholder="e.g. Sonoma Vista Residence"></div>
    <div class="field-row">
      <div class="field"><label>Date</label><input type="date" id="hoursDate"></div>
      <div class="field"><label>Hours</label><input type="number" id="hoursAmount" min="0" max="24" step="0.5" placeholder="8"></div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" onclick="closeModal('hoursModal')">Cancel</button>
      <button class="btn" onclick="saveHours()">Log Hours</button>
    </div>
  </div>
</div>

<script>
// ---- Data layer (in-memory, seeded) ----
var STATUS_LABELS={planning:'Planning',foundation:'Foundation',framing:'Framing',rough:'Rough-In',finishing:'Finishing',inspection:'Inspection',complete:'Complete'};

var jobs=[
  {id:'j1',name:'Sonoma Vista Residence',client:'The Andersons',location:'Santa Rosa, CA',status:'framing',progress:45,crew:5,date:'2026-09-15'},
  {id:'j2',name:'Valley View Estate',client:'M. Reynolds',location:'Sonoma, CA',status:'finishing',progress:78,crew:4,date:'2026-07-30'},
  {id:'j3',name:'Hillside ADU Project',client:'J. Castellano',location:'Napa, CA',status:'rough',progress:55,crew:3,date:'2026-08-20'},
  {id:'j4',name:'Calistoga Pool & Deck',client:'The Bennetts',location:'Calistoga, CA',status:'foundation',progress:20,crew:2,date:'2026-08-10'}
];
var crew=[
  {id:'c1',name:'Mike Torres',role:'Lead Framer',assign:'Sonoma Vista Residence',status:'on-site'},
  {id:'c2',name:'Danny Ruiz',role:'Carpenter',assign:'Valley View Estate',status:'on-site'},
  {id:'c3',name:'Carlos Mendez',role:'Concrete / Foundation',assign:'Calistoga Pool & Deck',status:'on-site'},
  {id:'c4',name:'Steve Park',role:'Electrician',assign:'Hillside ADU Project',status:'on-site'},
  {id:'c5',name:'Tom Walsh',role:'General Laborer',assign:'Unassigned',status:'off'}
];
var hours=[
  {id:'h1',name:'Mike Torres',site:'Sonoma Vista Residence',date:'2026-06-22',amount:8},
  {id:'h2',name:'Danny Ruiz',site:'Valley View Estate',date:'2026-06-22',amount:7.5},
  {id:'h3',name:'Carlos Mendez',site:'Calistoga Pool & Deck',date:'2026-06-22',amount:8},
  {id:'h4',name:'Steve Park',site:'Hillside ADU Project',date:'2026-06-21',amount:6}
];

// ---- Persistence (sessionStorage-free: use in-memory + window var) ----
function load(){
  try{
    var d=window.__HCI_DASH;
    if(d){jobs=d.jobs;crew=d.crew;hours=d.hours;}
  }catch(e){}
}
function save(){
  window.__HCI_DASH={jobs:jobs,crew:crew,hours:hours};
}

function uid(){return 'x'+Date.now()+Math.floor(Math.random()*1000);}

// ---- Render ----
function renderStats(){
  var active=jobs.filter(function(j){return j.status!=='complete';}).length;
  var now=new Date();var month=now.getMonth();var yr=now.getFullYear();
  var dueMonth=jobs.filter(function(j){if(!j.date)return false;var d=new Date(j.date);return d.getMonth()===month&&d.getFullYear()===yr;}).length;
  var onSite=crew.filter(function(c){return c.status==='on-site';}).length;
  var wkHours=hours.reduce(function(s,h){return s+(parseFloat(h.amount)||0);},0);
  document.getElementById('statActive').textContent=active;
  document.getElementById('statWeek').textContent=dueMonth;
  document.getElementById('statCrew').textContent=onSite;
  document.getElementById('statHours').textContent=wkHours;
}

function renderJobs(){
  var g=document.getElementById('jobsGrid');
  if(!jobs.length){g.innerHTML='<div class="empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg><p>No active jobs yet</p><span>Click \'New Job\' to add your first project.</span></div>';return;}
  g.innerHTML=jobs.map(function(j){
    return '<div class="job">'+
      '<div class="job-top"><div class="job-name-row"><div><div class="job-name">'+esc(j.name)+'</div><div class="job-client">'+esc(j.client)+'</div></div><span class="job-status s-'+j.status+'">'+STATUS_LABELS[j.status]+'</span></div></div>'+
      '<div class="job-body">'+
        '<div class="job-progress-lbl"><span>Progress</span><b>'+j.progress+'%</b></div>'+
        '<div class="progress-track"><div class="progress-fill" style="width:'+j.progress+'%"></div></div>'+
        '<div class="job-meta">'+
          '<div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>'+esc(j.location)+'</div>'+
          '<div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/></svg>'+j.crew+' crew</div>'+
          (j.date?'<div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>'+fmtDate(j.date)+'</div>':'')+
        '</div>'+
      '</div>'+
      '<div class="job-foot"><button onclick="editJob(\''+j.id+'\')">Edit</button><button onclick="delJob(\''+j.id+'\')">Remove</button></div>'+
    '</div>';
  }).join('');
}

function renderCrew(){
  var g=document.getElementById('crewGrid');
  if(!crew.length){g.innerHTML='<div class="empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><p>No crew added yet</p><span>Click \'Add Crew\' to build your team list.</span></div>';return;}
  g.innerHTML=crew.map(function(c){
    var initials=c.name.split(' ').map(function(n){return n[0];}).join('').substring(0,2).toUpperCase();
    return '<div class="crew-card">'+
      '<div class="crew-top"><div class="crew-av">'+initials+'</div><div><div class="crew-name">'+esc(c.name)+'</div><div class="crew-role">'+esc(c.role)+'</div></div><span class="crew-status '+(c.status==='on-site'?'on-site':'off')+'">'+(c.status==='on-site'?'On Site':'Off')+'</span></div>'+
      '<div class="crew-assign"><span>Assigned to</span><br>'+esc(c.assign||'Unassigned')+'</div>'+
      '<div class="job-foot" style="background:none;border:none;padding:10px 0 0;"><button onclick="editCrew(\''+c.id+'\')">Edit</button><button onclick="delCrew(\''+c.id+'\')">Remove</button></div>'+
    '</div>';
  }).join('');
}

function renderHours(){
  var t=document.getElementById('hoursTable');
  var rows='<div class="hours-row head"><div>Crew</div><div class="h-site">Job Site</div><div>Date</div><div>Hours</div></div>';
  if(!hours.length){t.innerHTML=rows+'<div class="empty"><p>No hours logged yet</p><span>Click \'Log Hours\' to record time.</span></div>';return;}
  rows+=hours.map(function(h){
    return '<div class="hours-row"><div class="h-name">'+esc(h.name)+'</div><div class="h-site">'+esc(h.site)+'</div><div>'+fmtDate(h.date)+'</div><div class="hours-total">'+h.amount+'h</div></div>';
  }).join('');
  var total=hours.reduce(function(s,h){return s+(parseFloat(h.amount)||0);},0);
  rows+='<div class="hours-row" style="background:#F7FAFD;font-weight:700;"><div class="h-name">Total</div><div class="h-site"></div><div></div><div class="hours-total">'+total+'h</div></div>';
  t.innerHTML=rows;
}

function renderAll(){renderStats();renderJobs();renderCrew();renderHours();save();}

// ---- Helpers ----
function esc(s){return String(s||'').replace(/[&<>"]/g,function(m){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m];});}
function fmtDate(d){if(!d)return '';var dt=new Date(d+'T00:00:00');return dt.toLocaleDateString('en-US',{month:'short',day:'numeric'});}

// ---- Tabs ----
document.querySelectorAll('.tab').forEach(function(t){
  t.addEventListener('click',function(){
    document.querySelectorAll('.tab').forEach(function(x){x.classList.remove('active');});
    document.querySelectorAll('.panel').forEach(function(x){x.classList.remove('active');});
    t.classList.add('active');
    document.getElementById('panel-'+t.dataset.tab).classList.add('active');
  });
});

// ---- Modals ----
function openModal(id){document.getElementById(id).classList.add('show');}
function closeModal(id){document.getElementById(id).classList.remove('show');}
document.querySelectorAll('.modal-bg').forEach(function(m){m.addEventListener('click',function(e){if(e.target===m)closeModal(m.id);});});

function openJobModal(){document.getElementById('jobModalTitle').textContent='New Job';document.getElementById('jobId').value='';document.getElementById('jobName').value='';document.getElementById('jobClient').value='';document.getElementById('jobLocation').value='';document.getElementById('jobStatus').value='planning';document.getElementById('jobProgress').value=0;document.getElementById('jobCrew').value=0;document.getElementById('jobDate').value='';openModal('jobModal');}
function editJob(id){var j=jobs.find(function(x){return x.id===id;});if(!j)return;document.getElementById('jobModalTitle').textContent='Edit Job';document.getElementById('jobId').value=j.id;document.getElementById('jobName').value=j.name;document.getElementById('jobClient').value=j.client;document.getElementById('jobLocation').value=j.location;document.getElementById('jobStatus').value=j.status;document.getElementById('jobProgress').value=j.progress;document.getElementById('jobCrew').value=j.crew;document.getElementById('jobDate').value=j.date||'';openModal('jobModal');}
function saveJob(){var id=document.getElementById('jobId').value;var name=document.getElementById('jobName').value.trim();if(!name){alert('Please enter a project name.');return;}var data={name:name,client:document.getElementById('jobClient').value.trim(),location:document.getElementById('jobLocation').value.trim(),status:document.getElementById('jobStatus').value,progress:Math.min(100,Math.max(0,parseInt(document.getElementById('jobProgress').value)||0)),crew:parseInt(document.getElementById('jobCrew').value)||0,date:document.getElementById('jobDate').value};if(id){var j=jobs.find(function(x){return x.id===id;});Object.assign(j,data);}else{data.id=uid();jobs.unshift(data);}closeModal('jobModal');renderAll();}
function delJob(id){if(confirm('Remove this job?')){jobs=jobs.filter(function(x){return x.id!==id;});renderAll();}}

function openCrewModal(){document.getElementById('crewModalTitle').textContent='Add Crew Member';document.getElementById('crewId').value='';document.getElementById('crewName').value='';document.getElementById('crewRole').value='';document.getElementById('crewAssign').value='';document.getElementById('crewStatus').value='on-site';openModal('crewModal');}
function editCrew(id){var c=crew.find(function(x){return x.id===id;});if(!c)return;document.getElementById('crewModalTitle').textContent='Edit Crew Member';document.getElementById('crewId').value=c.id;document.getElementById('crewName').value=c.name;document.getElementById('crewRole').value=c.role;document.getElementById('crewAssign').value=c.assign;document.getElementById('crewStatus').value=c.status;openModal('crewModal');}
function saveCrew(){var id=document.getElementById('crewId').value;var name=document.getElementById('crewName').value.trim();if(!name){alert('Please enter a name.');return;}var data={name:name,role:document.getElementById('crewRole').value.trim(),assign:document.getElementById('crewAssign').value.trim(),status:document.getElementById('crewStatus').value};if(id){var c=crew.find(function(x){return x.id===id;});Object.assign(c,data);}else{data.id=uid();crew.push(data);}closeModal('crewModal');renderAll();}
function delCrew(id){if(confirm('Remove this crew member?')){crew=crew.filter(function(x){return x.id!==id;});renderAll();}}

function openHoursModal(){document.getElementById('hoursName').value='';document.getElementById('hoursSite').value='';document.getElementById('hoursDate').value=new Date().toISOString().split('T')[0];document.getElementById('hoursAmount').value='';openModal('hoursModal');}
function saveHours(){var name=document.getElementById('hoursName').value.trim();var amt=parseFloat(document.getElementById('hoursAmount').value);if(!name||!amt){alert('Please enter a name and hours.');return;}hours.unshift({id:uid(),name:name,site:document.getElementById('hoursSite').value.trim(),date:document.getElementById('hoursDate').value||new Date().toISOString().split('T')[0],amount:amt});closeModal('hoursModal');renderAll();}

// ---- Init ----
document.getElementById('dashDate').textContent=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
load();renderAll();
</script>
