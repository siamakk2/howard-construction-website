<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 340 76" width="340" height="76">
  <!-- Solid white pill background so logo is always readable on ANY background -->
  <rect x="0" y="0" width="340" height="76" rx="6" fill="#FFFFFF"/>
  <!-- Thin blue border for definition -->
  <rect x="0" y="0" width="340" height="76" rx="6" fill="none" stroke="#1565C0" stroke-width="2"/>

  <!-- HOUSE ICON — solid, bold, blue -->
  <g transform="translate(10, 8)">
    <!-- Chimney -->
    <rect x="38" y="2" width="9" height="15" rx="1" fill="#0D47A1"/>
    <!-- Roof — deep navy so it pops -->
    <polygon points="30,18 2,38 58,38" fill="#0D47A1"/>
    <!-- Roof highlight line -->
    <polygon points="30,18 2,38 8,38 30,23 52,38 58,38" fill="#1565C0" opacity="0.4"/>
    <!-- House body -->
    <rect x="8" y="36" width="44" height="28" rx="1" fill="#1565C0"/>
    <!-- Door — white so it reads clearly -->
    <rect x="22" y="46" width="16" height="18" rx="2" fill="#FFFFFF"/>
    <!-- Door arch -->
    <ellipse cx="30" cy="46" rx="8" ry="5" fill="#FFFFFF"/>
    <!-- Door knob -->
    <circle cx="35" cy="55" r="1.8" fill="#0D47A1"/>
    <!-- Left window — white with blue frame -->
    <rect x="10" y="40" width="10" height="9" rx="1" fill="#E3F2FD" stroke="#0D47A1" stroke-width="1"/>
    <line x1="15" y1="40" x2="15" y2="49" stroke="#0D47A1" stroke-width="0.8"/>
    <line x1="10" y1="44.5" x2="20" y2="44.5" stroke="#0D47A1" stroke-width="0.8"/>
    <!-- Right window -->
    <rect x="40" y="40" width="10" height="9" rx="1" fill="#E3F2FD" stroke="#0D47A1" stroke-width="1"/>
    <line x1="45" y1="40" x2="45" y2="49" stroke="#0D47A1" stroke-width="0.8"/>
    <line x1="40" y1="44.5" x2="50" y2="44.5" stroke="#0D47A1" stroke-width="0.8"/>
    <!-- Gold accent star at peak -->
    <polygon points="30,11 31.8,16.5 37.5,16.5 33,19.8 34.8,25.3 30,22 25.2,25.3 27,19.8 22.5,16.5 28.2,16.5" fill="#F9A825"/>
  </g>

  <!-- Vertical divider -->
  <line x1="82" y1="10" x2="82" y2="66" stroke="#BBDEFB" stroke-width="1.5"/>

  <!-- HOWARD — very dark navy, max legibility -->
  <text x="94" y="42"
        font-family="Georgia, 'Times New Roman', serif"
        font-size="30"
        font-weight="900"
        fill="#0A1628"
        letter-spacing="-0.5">HOWARD</text>

  <!-- CONSTRUCTION — medium blue, clearly readable -->
  <text x="94" y="58"
        font-family="'Arial Black', Arial, Helvetica, sans-serif"
        font-size="13.5"
        font-weight="900"
        fill="#1565C0"
        letter-spacing="3">CONSTRUCTION</text>

  <!-- INC — gold accent -->
  <text x="94" y="70"
        font-family="Arial, Helvetica, sans-serif"
        font-size="9.5"
        font-weight="700"
        fill="#F9A825"
        letter-spacing="2.5">INC. &bull; SANTA ROSA, CA &bull; EST. 2000</text>
</svg>
