<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#0A1628"/>
      <stop offset="35%" stop-color="#0D2A4A"/>
      <stop offset="65%" stop-color="#1A4A7A"/>
      <stop offset="100%" stop-color="#2E6FA3"/>
    </linearGradient>
    <linearGradient id="sun-glow" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFD700" stop-opacity="0.9"/>
      <stop offset="100%" stop-color="#FF8C00" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="hill-far" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1A3A5C"/>
      <stop offset="100%" stop-color="#0D2240"/>
    </linearGradient>
    <linearGradient id="hill-mid" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1E5C2A"/>
      <stop offset="100%" stop-color="#0F3015"/>
    </linearGradient>
    <linearGradient id="hill-near" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#0F3A18"/>
      <stop offset="100%" stop-color="#071A0A"/>
    </linearGradient>
    <linearGradient id="valley" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1A4A28"/>
      <stop offset="100%" stop-color="#0A2010"/>
    </linearGradient>
    <radialGradient id="sun" cx="75%" cy="20%" r="20%">
      <stop offset="0%" stop-color="#FFD700" stop-opacity="0.95"/>
      <stop offset="30%" stop-color="#FFA500" stop-opacity="0.4"/>
      <stop offset="70%" stop-color="#FF6B00" stop-opacity="0.1"/>
      <stop offset="100%" stop-color="#FF6B00" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="moon-glow" cx="20%" cy="15%" r="15%">
      <stop offset="0%" stop-color="#B8D4FF" stop-opacity="0.5"/>
      <stop offset="100%" stop-color="#B8D4FF" stop-opacity="0"/>
    </radialGradient>
    <filter id="blur-sm"><feGaussianBlur stdDeviation="3"/></filter>
    <filter id="blur-md"><feGaussianBlur stdDeviation="8"/></filter>
    <filter id="glow"><feGaussianBlur stdDeviation="12" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
    <linearGradient id="overlay" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#030E1F" stop-opacity="0.88"/>
      <stop offset="50%" stop-color="#030E1F" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="#030E1F" stop-opacity="0.25"/>
    </linearGradient>
    <linearGradient id="bottom-fade" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#030E1F" stop-opacity="0"/>
      <stop offset="100%" stop-color="#030E1F" stop-opacity="0.7"/>
    </linearGradient>
  </defs>

  <!-- SKY -->
  <rect width="1600" height="900" fill="url(#sky)"/>

  <!-- Stars -->
  <g opacity="0.7">
    <circle cx="120" cy="60" r="1.2" fill="white" opacity="0.9"/>
    <circle cx="280" cy="40" r="0.8" fill="white" opacity="0.7"/>
    <circle cx="420" cy="80" r="1.5" fill="white" opacity="0.85"/>
    <circle cx="560" cy="30" r="0.9" fill="white" opacity="0.6"/>
    <circle cx="650" cy="70" r="1.1" fill="white" opacity="0.8"/>
    <circle cx="200" cy="120" r="0.7" fill="white" opacity="0.65"/>
    <circle cx="350" cy="100" r="1.0" fill="white" opacity="0.75"/>
    <circle cx="480" cy="55" r="0.8" fill="white"/>
    <circle cx="90" cy="150" r="1.3" fill="white" opacity="0.7"/>
    <circle cx="700" cy="45" r="0.9" fill="white" opacity="0.8"/>
    <circle cx="180" cy="200" r="0.6" fill="white" opacity="0.5"/>
    <circle cx="320" cy="170" r="1.1" fill="white" opacity="0.7"/>
    <circle cx="50" cy="220" r="0.8" fill="white" opacity="0.6"/>
  </g>

  <!-- Milky Way band -->
  <ellipse cx="400" cy="200" rx="500" ry="80" fill="rgba(150,180,255,0.04)" filter="url(#blur-md)"/>
  <ellipse cx="350" cy="180" rx="400" ry="50" fill="rgba(180,200,255,0.03)" filter="url(#blur-md)"/>

  <!-- Sun / Moon glow on horizon right side -->
  <ellipse cx="1200" cy="320" rx="300" ry="200" fill="url(#sun-glow)" filter="url(#blur-md)" opacity="0.6"/>
  <circle cx="1200" cy="300" r="60" fill="#FFD080" opacity="0.85" filter="url(#glow)"/>
  <circle cx="1200" cy="300" r="42" fill="#FFE8A0" opacity="0.95"/>
  <circle cx="1200" cy="300" r="28" fill="#FFFACD"/>

  <!-- Moon glow left -->
  <ellipse cx="160" cy="140" rx="200" ry="120" fill="url(#moon-glow)" filter="url(#blur-md)"/>

  <!-- Atmospheric haze on horizon -->
  <ellipse cx="800" cy="500" rx="900" ry="120" fill="rgba(100,160,220,0.12)" filter="url(#blur-md)"/>

  <!-- FAR HILLS - mountain range Sonoma/Napa -->
  <path d="M0 520 Q100 420 200 450 Q300 400 400 430 Q500 390 600 420 Q700 380 800 410 Q900 370 1000 400 Q1100 360 1200 390 Q1300 350 1400 380 Q1500 360 1600 400 L1600 900 L0 900Z" fill="url(#hill-far)" opacity="0.9"/>

  <!-- MID HILLS with vineyard suggestion -->
  <path d="M0 580 Q80 530 180 555 Q280 510 380 545 Q470 505 570 535 Q660 500 760 530 Q860 495 960 525 Q1060 490 1160 520 Q1260 485 1360 515 Q1450 490 1600 510 L1600 900 L0 900Z" fill="url(#hill-mid)"/>

  <!-- Vineyard rows on mid hill -->
  <g opacity="0.25" fill="none" stroke="#3A7A4A" stroke-width="2">
    <path d="M100 590 Q200 575 300 585"/>
    <path d="M100 605 Q200 590 300 600"/>
    <path d="M100 620 Q200 605 300 615"/>
    <path d="M350 575 Q450 560 550 570"/>
    <path d="M350 590 Q450 575 550 585"/>
    <path d="M350 605 Q450 590 550 600"/>
    <path d="M600 565 Q700 550 800 560"/>
    <path d="M600 580 Q700 565 800 575"/>
    <path d="M900 560 Q1000 545 1100 555"/>
    <path d="M900 575 Q1000 560 1100 570"/>
  </g>

  <!-- River / valley floor -->
  <path d="M0 650 Q200 620 400 640 Q600 615 800 635 Q1000 610 1200 630 Q1400 615 1600 625 L1600 900 L0 900Z" fill="url(#valley)"/>

  <!-- Winding road/river suggestion -->
  <path d="M300 700 Q500 660 700 680 Q900 660 1100 670 Q1300 655 1500 660" fill="none" stroke="rgba(150,200,255,0.15)" stroke-width="12" stroke-linecap="round"/>
  <path d="M300 700 Q500 660 700 680 Q900 660 1100 670 Q1300 655 1500 660" fill="none" stroke="rgba(150,200,255,0.08)" stroke-width="24" stroke-linecap="round"/>

  <!-- NEAR HILLS - foreground -->
  <path d="M0 720 Q150 680 300 700 Q450 665 600 690 Q750 660 900 685 Q1050 655 1200 675 Q1350 650 1600 665 L1600 900 L0 900Z" fill="url(#hill-near)"/>

  <!-- Trees silhouette on near hill - California Oaks -->
  <g fill="#071508">
    <!-- Left cluster -->
    <ellipse cx="80" cy="710" rx="45" ry="50"/>
    <rect x="76" y="730" width="8" height="40"/>
    <ellipse cx="150" cy="700" rx="35" ry="42"/>
    <rect x="146" y="718" width="8" height="42"/>
    <ellipse cx="220" cy="715" rx="50" ry="55"/>
    <rect x="216" y="738" width="8" height="40"/>
    
    <!-- Mid-left cluster -->
    <ellipse cx="380" cy="700" rx="40" ry="48"/>
    <rect x="376" y="720" width="8" height="42"/>
    <ellipse cx="440" cy="692" rx="32" ry="38"/>
    <rect x="436" y="710" width="7" height="40"/>

    <!-- Center -->
    <ellipse cx="680" cy="705" rx="44" ry="52"/>
    <rect x="676" y="726" width="8" height="42"/>
    <ellipse cx="750" cy="695" rx="36" ry="44"/>
    <rect x="746" y="716" width="7" height="40"/>

    <!-- Right cluster -->
    <ellipse cx="1050" cy="700" rx="42" ry="50"/>
    <rect x="1046" y="720" width="8" height="42"/>
    <ellipse cx="1120" cy="708" rx="38" ry="46"/>
    <rect x="1116" y="728" width="8" height="40"/>
    <ellipse cx="1300" cy="695" rx="48" ry="54"/>
    <rect x="1296" y="718" width="8" height="42"/>
    <ellipse cx="1380" cy="705" rx="35" ry="42"/>
    <rect x="1376" y="725" width="7" height="38"/>
    <ellipse cx="1500" cy="700" rx="42" ry="50"/>
    <rect x="1496" y="720" width="8" height="40"/>
  </g>

  <!-- Lights in valley - towns of Sonoma/Napa -->
  <g opacity="0.6">
    <circle cx="400" cy="720" r="2" fill="#FFD700"/>
    <circle cx="420" cy="715" r="1.5" fill="#FFE080"/>
    <circle cx="450" cy="722" r="2.5" fill="#FFD700"/>
    <circle cx="480" cy="718" r="1.8" fill="#FFE080"/>
    <circle cx="510" cy="725" r="2" fill="#FFD700"/>
    <circle cx="540" cy="720" r="1.5" fill="white"/>
    <circle cx="700" cy="715" r="2" fill="#FFD700"/>
    <circle cx="730" cy="720" r="2.5" fill="#FFE080"/>
    <circle cx="760" cy="714" r="1.8" fill="#FFD700"/>
    <circle cx="900" cy="718" r="2" fill="#FFD700"/>
    <circle cx="930" cy="722" r="1.5" fill="white"/>
    <circle cx="960" cy="716" r="2" fill="#FFE080"/>
    <circle cx="1100" cy="720" r="2.5" fill="#FFD700"/>
    <circle cx="1130" cy="715" r="1.8" fill="#FFE080"/>
    <circle cx="1160" cy="721" r="2" fill="white"/>
  </g>

  <!-- City glow halos under lights -->
  <ellipse cx="470" cy="730" rx="80" ry="15" fill="rgba(255,200,50,0.08)" filter="url(#blur-sm)"/>
  <ellipse cx="730" cy="725" rx="60" ry="12" fill="rgba(255,200,50,0.07)" filter="url(#blur-sm)"/>
  <ellipse cx="1130" cy="728" rx="70" ry="13" fill="rgba(255,200,50,0.08)" filter="url(#blur-sm)"/>

  <!-- Atmospheric perspective rays from sun -->
  <g opacity="0.06" filter="url(#blur-md)">
    <path d="M1200 300 L400 900 L600 900Z" fill="#FFD700"/>
    <path d="M1200 300 L800 900 L1000 900Z" fill="#FFD700"/>
    <path d="M1200 300 L1100 900 L1300 900Z" fill="#FFD700"/>
  </g>

  <!-- MAIN OVERLAY - left side dark for text legibility -->
  <rect width="1600" height="900" fill="url(#overlay)"/>
  
  <!-- Bottom fade -->
  <rect width="1600" height="900" fill="url(#bottom-fade)"/>

  <!-- Subtle grid texture overlay -->
  <rect width="1600" height="900" fill="url(#sky)" opacity="0.03"/>
</svg>
